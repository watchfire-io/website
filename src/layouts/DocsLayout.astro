---
import BaseLayout from './BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import DocsSidebar from '../components/DocsSidebar.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<BaseLayout title={`${title} — Watchfire Docs`} description={description}>
  <Navbar />

  <div class="mx-auto flex w-full max-w-7xl px-6 pt-24 pb-16">
    <!-- Sidebar: hidden on mobile, shown on lg+ -->
    <div class="hidden w-64 shrink-0 lg:block">
      <DocsSidebar />
    </div>

    <!-- Mobile sidebar toggle -->
    <button
      class="fixed bottom-6 right-6 z-40 flex h-12 w-12 items-center justify-center rounded-full bg-fire text-charcoal shadow-lg lg:hidden"
      id="sidebar-toggle"
      aria-label="Toggle docs sidebar"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="6" x2="21" y2="6" />
        <line x1="3" y1="12" x2="15" y2="12" />
        <line x1="3" y1="18" x2="18" y2="18" />
      </svg>
    </button>

    <!-- Mobile sidebar overlay -->
    <div class="fixed inset-0 z-30 hidden bg-charcoal/80 backdrop-blur-sm lg:hidden" id="sidebar-overlay">
      <div class="h-full w-72 overflow-y-auto border-r border-border bg-charcoal p-4 pt-20">
        <DocsSidebar />
      </div>
    </div>

    <!-- Content area -->
    <main class="min-w-0 flex-1 lg:pl-10">
      <article class="docs-prose">
        <slot />
      </article>
    </main>
  </div>
</BaseLayout>

<style is:global>
  /* ===== Docs Prose Typography ===== */
  .docs-prose h1 {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    font-weight: 700;
    line-height: 1.1;
    color: var(--color-flame);
    margin-bottom: 1.5rem;
  }

  .docs-prose h2 {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 600;
    line-height: 1.2;
    color: var(--color-flame);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .docs-prose h3 {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--color-flame);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .docs-prose h4 {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 600;
    line-height: 1.4;
    color: var(--color-body);
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .docs-prose p {
    margin-bottom: 1.25rem;
    line-height: 1.7;
  }

  .docs-prose a {
    color: var(--color-fire);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.2s ease;
  }

  .docs-prose a:hover {
    color: var(--color-ember);
  }

  .docs-prose strong {
    font-weight: 600;
    color: var(--color-flame);
  }

  /* Lists */
  .docs-prose ul {
    list-style-type: disc;
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .docs-prose ol {
    list-style-type: decimal;
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .docs-prose li {
    margin-bottom: 0.5rem;
    line-height: 1.7;
  }

  .docs-prose li > ul,
  .docs-prose li > ol {
    margin-top: 0.5rem;
    margin-bottom: 0;
  }

  /* Code */
  .docs-prose code {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    background: var(--color-elevated);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 0.15rem 0.4rem;
  }

  .docs-prose pre {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    line-height: 1.6;
    background: var(--color-elevated);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.25rem;
    margin-bottom: 1.5rem;
    overflow-x: auto;
  }

  .docs-prose pre code {
    background: none;
    border: none;
    border-radius: 0;
    padding: 0;
    font-size: inherit;
  }

  /* Tables */
  .docs-prose table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
  }

  .docs-prose th {
    text-align: left;
    font-weight: 600;
    color: var(--color-flame);
    padding: 0.75rem 1rem;
    border-bottom: 2px solid var(--color-border);
    background: var(--color-card);
  }

  .docs-prose td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--color-border);
  }

  .docs-prose tr:nth-child(even) td {
    background: var(--color-card);
  }

  /* Blockquotes */
  .docs-prose blockquote {
    border-left: 3px solid var(--color-fire);
    padding: 0.75rem 1.25rem;
    margin-bottom: 1.5rem;
    background: var(--color-card);
    border-radius: 0 8px 8px 0;
  }

  .docs-prose blockquote p:last-child {
    margin-bottom: 0;
  }

  /* Horizontal rules */
  .docs-prose hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2.5rem 0;
  }

  /* Images */
  .docs-prose img {
    max-width: 100%;
    border-radius: 8px;
    margin-bottom: 1.5rem;
  }
</style>

<script>
  const toggle = document.getElementById('sidebar-toggle');
  const overlay = document.getElementById('sidebar-overlay');

  toggle?.addEventListener('click', () => {
    overlay?.classList.toggle('hidden');
    document.body.style.overflow = overlay?.classList.contains('hidden') ? '' : 'hidden';
  });

  overlay?.addEventListener('click', (e) => {
    if (e.target === overlay) {
      overlay.classList.add('hidden');
      document.body.style.overflow = '';
    }
  });
</script>
