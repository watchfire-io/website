---
import { Github } from "lucide-astro";
---

<nav class="fixed top-0 left-0 right-0 z-50 border-b border-border/50" id="navbar">
  <div class="absolute inset-0 bg-charcoal/80 backdrop-blur-xl"></div>
  <div class="relative mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
    <!-- Wordmark -->
    <a href="/" class="font-display text-xl font-700 tracking-wider text-flame transition-colors hover:text-fire">
      WATCHFIRE
    </a>

    <!-- Desktop nav -->
    <div class="hidden items-center gap-8 md:flex">
      <a href="#features" class="text-sm font-500 text-muted transition-colors hover:text-flame">
        Features
      </a>
      <a href="/docs" class="text-sm font-500 text-muted transition-colors hover:text-flame">
        Docs
      </a>
      <a
        href="https://github.com/watchfire-io/watchfire"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-1.5 text-sm font-500 text-muted transition-colors hover:text-flame"
      >
        <Github size={16} />
        GitHub
      </a>
      <a
        href="https://github.com/watchfire-io/watchfire/releases/latest"
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-lg bg-fire px-4 py-2 text-sm font-600 text-charcoal transition-all hover:bg-fire-hover hover:shadow-[0_0_20px_rgba(224,112,64,0.3)]"
      >
        Get Watchfire
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button
      class="relative z-10 flex h-8 w-8 flex-col items-center justify-center gap-1.5 md:hidden"
      id="mobile-toggle"
      aria-label="Toggle navigation"
    >
      <span class="hamburger-line block h-0.5 w-5 rounded-full bg-flame transition-all duration-200"></span>
      <span class="hamburger-line block h-0.5 w-5 rounded-full bg-flame transition-all duration-200"></span>
      <span class="hamburger-line block h-0.5 w-3.5 rounded-full bg-flame transition-all duration-200 self-end"></span>
    </button>
  </div>

  <!-- Mobile overlay -->
  <div
    class="fixed inset-0 top-0 z-40 hidden bg-charcoal/95 backdrop-blur-xl md:hidden"
    id="mobile-menu"
  >
    <div class="flex h-full flex-col items-center justify-center gap-8">
      <a href="#features" class="mobile-link text-2xl font-500 text-muted transition-colors hover:text-flame">
        Features
      </a>
      <a href="/docs" class="mobile-link text-2xl font-500 text-muted transition-colors hover:text-flame">
        Docs
      </a>
      <a
        href="https://github.com/watchfire-io/watchfire"
        target="_blank"
        rel="noopener noreferrer"
        class="mobile-link flex items-center gap-2 text-2xl font-500 text-muted transition-colors hover:text-flame"
      >
        <Github size={20} />
        GitHub
      </a>
      <a
        href="https://github.com/watchfire-io/watchfire/releases/latest"
        target="_blank"
        rel="noopener noreferrer"
        class="mobile-link mt-4 rounded-lg bg-fire px-6 py-3 text-lg font-600 text-charcoal transition-all hover:bg-fire-hover"
      >
        Get Watchfire
      </a>
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById("mobile-toggle");
  const menu = document.getElementById("mobile-menu");
  const lines = toggle?.querySelectorAll(".hamburger-line");
  const mobileLinks = menu?.querySelectorAll(".mobile-link");
  let open = false;

  function setMenu(state: boolean) {
    open = state;
    if (open) {
      menu?.classList.remove("hidden");
      menu?.classList.add("flex");
      if (lines) {
        (lines[0] as HTMLElement).style.transform = "rotate(45deg) translate(3px, 3px)";
        (lines[1] as HTMLElement).style.opacity = "0";
        (lines[2] as HTMLElement).style.transform = "rotate(-45deg) translate(3px, -3px)";
        (lines[2] as HTMLElement).style.width = "1.25rem";
      }
      document.body.style.overflow = "hidden";
    } else {
      menu?.classList.add("hidden");
      menu?.classList.remove("flex");
      if (lines) {
        (lines[0] as HTMLElement).style.transform = "";
        (lines[1] as HTMLElement).style.opacity = "1";
        (lines[2] as HTMLElement).style.transform = "";
        (lines[2] as HTMLElement).style.width = "";
      }
      document.body.style.overflow = "";
    }
  }

  toggle?.addEventListener("click", () => setMenu(!open));
  mobileLinks?.forEach((link) => link.addEventListener("click", () => setMenu(false)));
</script>
