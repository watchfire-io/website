---
import {
  Layers,
  ListChecks,
  ShieldCheck,
  Radio,
  GitBranch,
  Flame,
  TerminalSquare,
  MonitorDot,
} from "lucide-astro";

const features = [
  {
    icon: Layers,
    title: "Multi-project orchestration",
    description: "Manage multiple projects in parallel with independent task queues and a single daemon controlling it all.",
  },
  {
    icon: ListChecks,
    title: "Task workflow",
    description: "Complete lifecycle from draft to done — automatic agent assignment, status tracking, and completion detection.",
  },
  {
    icon: ShieldCheck,
    title: "Sandboxed agents",
    description: "Coding agents run in isolated PTY environments with configurable sandbox security policies.",
  },
  {
    icon: Radio,
    title: "Live terminal streaming",
    description: "Real-time agent output with full VT100 terminal emulation streamed over gRPC to any connected client.",
  },
  {
    icon: GitBranch,
    title: "Git worktree integration",
    description: "Automatic branch creation, isolated worktrees per task, and clean merging back to your main branch.",
  },
  {
    icon: Flame,
    title: "Wildfire mode",
    description: "Three-phase autonomous loop — execute tasks, refine results, then generate new tasks. Full autopilot.",
  },
  {
    icon: TerminalSquare,
    title: "TUI interface",
    description: "Split-panel terminal UI with vim-style navigation, mouse support, and draggable panel dividers.",
  },
  {
    icon: MonitorDot,
    title: "System tray",
    description: "Background daemon with colored status indicators per project — always know what your agents are doing.",
  },
];
---

<section id="features" class="relative py-24 md:py-32">
  <!-- Section background -->
  <div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-transparent via-card/30 to-transparent"></div>

  <div class="relative mx-auto max-w-7xl px-6">
    <!-- Section header -->
    <div class="mx-auto mb-16 max-w-2xl text-center">
      <span class="mb-4 inline-block font-mono text-xs font-500 uppercase tracking-widest text-fire">
        Capabilities
      </span>
      <h2 class="font-heading text-3xl font-600 tracking-tight text-flame sm:text-4xl md:text-[2.75rem]">
        Everything you need to orchestrate AI agents
      </h2>
      <p class="mt-4 text-muted">
        From task management to live terminal streaming, Watchfire handles the infrastructure so your agents can focus on code.
      </p>
    </div>

    <!-- Feature grid -->
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {features.map((feature, i) => (
        <div
          class="group relative rounded-xl border border-border bg-card/60 p-6 backdrop-blur-sm transition-all duration-200 hover:border-border hover:bg-card hover:shadow-[0_4px_24px_rgba(0,0,0,0.3)]"
          style={`animation-delay: ${i * 60}ms`}
        >
          <!-- Icon -->
          <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-elevated text-fire transition-colors group-hover:text-ember">
            <feature.icon size={20} />
          </div>

          <!-- Content -->
          <h3 class="mb-2 font-heading text-[0.95rem] font-600 text-flame">
            {feature.title}
          </h3>
          <p class="text-sm leading-relaxed text-muted">
            {feature.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
