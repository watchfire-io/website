---
const steps = [
  {
    number: "01",
    title: "Initialize",
    description: "Run a single command in any project directory to set up Watchfire orchestration.",
    code: "watchfire init",
  },
  {
    number: "02",
    title: "Create tasks",
    description: "Define what needs to be done in simple YAML task files — or let agents generate them for you.",
    code: 'watchfire task add "Build auth flow"',
  },
  {
    number: "03",
    title: "Agents execute",
    description: "AI coding agents pick up tasks, work in isolated git branches, and merge results when done.",
    code: "watchfire agent start all",
  },
];
---

<section class="relative py-24 md:py-32">
  <div class="mx-auto max-w-6xl px-6">
    <!-- Section header -->
    <div class="mx-auto mb-16 max-w-2xl text-center">
      <span class="mb-4 inline-block font-mono text-xs font-500 uppercase tracking-widest text-fire">
        Workflow
      </span>
      <h2 class="font-heading text-3xl font-600 tracking-tight text-flame sm:text-4xl md:text-[2.75rem]">
        Three commands to autopilot
      </h2>
      <p class="mt-4 text-muted">
        Go from zero to fully orchestrated AI development in under a minute.
      </p>
    </div>

    <!-- Steps -->
    <div class="relative grid gap-8 md:grid-cols-3 md:gap-6">
      <!-- Connector lines (desktop only) -->
      <div class="pointer-events-none absolute top-12 right-1/3 left-1/3 hidden h-px md:block">
        <div class="h-full w-full border-t border-dashed border-border"></div>
      </div>

      {steps.map((step) => (
        <div class="relative">
          <!-- Step number -->
          <div class="mb-5 flex items-center gap-4 md:flex-col md:items-center md:text-center">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-fire/30 bg-fire/10 font-mono text-sm font-500 text-fire">
              {step.number}
            </div>
            <h3 class="font-heading text-xl font-600 text-flame md:mt-4">
              {step.title}
            </h3>
          </div>

          <!-- Description -->
          <p class="mb-4 text-sm leading-relaxed text-muted md:text-center">
            {step.description}
          </p>

          <!-- Code snippet -->
          <div class="rounded-lg border border-border bg-charcoal p-3">
            <code class="font-mono text-sm text-ember">
              <span class="text-muted/50">$ </span>{step.code}
            </code>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
