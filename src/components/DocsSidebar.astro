---
import { getCollection } from 'astro:content';
import { ArrowLeft } from 'lucide-astro';

const docs = await getCollection('docs');
const sorted = docs.sort((a, b) => a.data.order - b.data.order);

const currentPath = Astro.url.pathname.replace(/\/$/, '');
---

<aside class="docs-sidebar" id="docs-sidebar">
  <div class="sticky top-20 flex flex-col gap-2 rounded-xl border border-border bg-card p-5">
    <a
      href="/"
      class="mb-3 flex items-center gap-1.5 text-sm font-500 text-muted transition-colors hover:text-flame"
    >
      <ArrowLeft size={14} />
      Back to home
    </a>

    <h3 class="mb-1 text-xs font-600 uppercase tracking-widest text-muted">
      Documentation
    </h3>

    <nav class="flex flex-col gap-0.5">
      {sorted.map((doc) => {
        const href = `/docs/${doc.id}`;
        const isActive = currentPath === href;
        return (
          <a
            href={href}
            class:list={[
              'rounded-lg px-3 py-2 text-sm font-500 transition-all duration-200',
              isActive
                ? 'bg-fire/10 text-fire border-l-2 border-fire pl-2.5'
                : 'text-body hover:bg-elevated hover:text-flame',
            ]}
          >
            {doc.data.title}
          </a>
        );
      })}
    </nav>
  </div>
</aside>
